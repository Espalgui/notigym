# Database
POSTGRES_USER=notigym
POSTGRES_PASSWORD=changeme_strong_password
POSTGRES_DB=notigym
DATABASE_URL=postgresql+asyncpg://notigym:changeme_strong_password@db:5432/notigym

# JWT
